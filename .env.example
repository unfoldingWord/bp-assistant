# Zulip bot credentials
ZULIP_API_KEY=your-zulip-api-key
ZULIP_EMAIL=your-bot@your-org.zulipchat.com
ZULIP_REALM=https://your-org.zulipchat.com

# Door43/Gitea API access (for pushing content to repos)
DCS_TOKEN=your-door43-api-token

# Anthropic API key (used by Haiku NLU intent classifier)
ANTHROPIC_API_KEY=your-anthropic-api-key

# HTTP port for MCP server (optional, default: 3001)
PORT=3001