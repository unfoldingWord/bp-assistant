{
  "adminUserId": null,
  "authorizedUserIds": [],
  "channel": "CONTENT - UR",
  "topics": [
    "Psalms BP",
    "AI Work",
    "Workflow",
    "BP Proofreading",
    "Proofreading Queue",
    "Jeremiah BP",
    "Bot testing"
  ],
  "watchDMs": true,
  "routes": [
    {
      "name": "editor-note",
      "match": "/note\\s+(\\w+)(?:\\s+(\\d+))?\\s+(.+)/i",
      "type": "editor-note",
      "reply": true,
      "confirmMessage": "I'll file this note for **$1**. Sound right? (yes/no)"
    },
    {
      "name": "generate-content",
      "match": "/generate\\s+(\\w+)\\s+(\\d+)(?:\\s*[-–—to]+\\s*(\\d+))?/i",
      "type": "sdk",
      "skill": "initial-pipeline --lite",
      "pipeline": "./pipelines/generate.sh",
      "reply": false,
      "confirmMessage": "I'll generate the initial content (ULT & UST, issues draft) for **$1 $2**. Sound right? (yes/no)",
      "operations": 3,
      "tokenEstimate": {
        "perChapter": 5000000,
        "sessionBudget": 45000000
      }
    },
    {
      "name": "write-notes",
      "match": "/write notes(?:\\s+for)?\\s+(\\w+)\\s+(\\d+(?::\\d+[-–—]\\d+)?(?:\\s*[-–—]\\s*\\d+)?)/i",
      "type": "notes",
      "reply": false,
      "confirmMessage": "I'll write translation notes for **$1 $2**. Sound right? (yes/no)",
      "operations": 1
    },
    {
      "name": "editor-review",
      "match": "/(\\w+)\\s+(\\d+(?:\\s*,\\s*\\d+)*(?:\\s*,?\\s*and\\s+\\d+)?).*?(?:review|compare)/i",
      "type": "interactive-dm",
      "cwd": "/workspace",
      "reply": true,
      "operations": 2,
      "maxExchanges": 6,
      "confirmMessage": "I'll compare the human-edited **$1 $2** ULT & UST against what the AI generated and identify improvements. Sound right? (yes/no)"
    }
  ],
  "defaultPipeline": null,
  "dmDefaultPipeline": {
    "name": "interactive-dm",
    "type": "interactive-dm",
    "reply": true,
    "cwd": "/workspace"
  },
  "unauthorizedReply": "You're not on the authorized list, ask the admin in the response.",
  "usageTracking": {
    "windowBudgetTokens": 220000,
    "windowHours": 5,
    "warnThreshold": 0.7,
    "ccusagePath": "npx ccusage@latest"
  }
}
