{
  "adminUserId": null,
  "authorizedUserIds": [],
  "channel": "81 English Book Packages",
  "topics": [
    "Psalms BP",
    "AI Work",
    "Workflow",
    "BP Proofreading",
    "Proofreading Queue",
    "Jeremiah BP",
    "Habakkuk BP",
    "Bot testing"
  ],
  "watchDMs": true,
  "routes": [
    {
      "name": "editor-note",
      "match": "/^note\\s+(\\w+)\\s+(.+)/i",
      "type": "editor-note",
      "reply": true,
      "confirmMessage": "I'll file this note for **$1**. Sound right? (yes/no)"
    },
    {
      "name": "generate-content",
      "match": "/generate\\s+(\\w+)\\s+(\\d+(?::\\d+(?:[-‚Äì‚Äî]\\d+)?)?(?:\\s*[-‚Äì‚Äîto]+\\s*\\d+)?)/i",
      "type": "sdk",
      "skill": "initial-pipeline",

      "reply": false,
      "confirmMessage": "I'll generate the initial content (ULT & UST, issues draft) for **$1 $2**. Sound right? (yes/no)",
      "operations": 6,
      "tokenEstimate": {
        "perChapter": 5000000,
        "sessionBudget": 45000000
      }
    },
    {
      "name": "write-notes",
      "match": "/write notes(?:\\s+for)?\\s+(\\w+)\\s+(\\d+(?::\\d+(?:[-‚Äì‚Äî]\\d+)?)?(?:\\s*[-‚Äì‚Äî]\\s*\\d+)?)/i",
      "type": "notes",
      "reply": false,
      "confirmMessage": "I'll write translation notes for **$1 $2**. Sound right? (yes/no)",
      "operations": 1
    },
    {
      "name": "editor-review",
      "match": "/(\\w+)\\s+(\\d+(?:\\s*,\\s*\\d+)*(?:\\s*,?\\s*and\\s+\\d+)?).*?(?:review|compare)/i",
      "type": "interactive-dm",
      "cwd": "/workspace",
      "reply": true,
      "operations": 2,
      "maxExchanges": 6,
      "confirmMessage": "I'll compare the human-edited **$1 $2** ULT & UST against what the AI generated and identify improvements. Sound right? (yes/no)"
    }
  ],
  "defaultPipeline": null,
  "dmDefaultPipeline": {
    "name": "interactive-dm",
    "type": "interactive-dm",
    "reply": true,
    "cwd": "/workspace",
    "model": "sonnet"
  },
  "unauthorizedReply": "You're not on the authorized list, ask the admin in the response.",
  "usageTracking": {
    "windowBudgetTokens": 220000,
    "windowHours": 5,
    "warnThreshold": 0.7,
    "ccusagePath": "npx ccusage@latest",
    "adaptiveGuards": {
      "enableTokenBudget": false,
      "minBudgetTokens": 120000,
      "maxBudgetTokens": 1400000,
      "wordFactor": 35,
      "issueFactor": 12000,
      "warmupSamples": 3,
      "warmupMultiplier": 1.0,
      "minMultiplier": 0.7,
      "maxMultiplier": 1.6,
      "hardMaxTurns": 1000,
      "hardMaxToolCalls": 1000,
      "maxConsecutiveToolErrors": 25,
      "maxRepeatedToolErrorSignature": 25
    }
  },
  "notesGuardrails": {
    "tnWriterParallelMinVerses": 35,
    "tnWriterMaxTurns": 150,
    "tnWriterMaxToolCalls": 400,
    "rescueMaxPasses": 1
  }
}
