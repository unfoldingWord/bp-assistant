# Host-side cron automation config.
# Copy this to /home/ubuntu/bp-bot/config/cron.env and adjust the paths for your host.

BP_BOT_HOME=/home/ubuntu/bp-bot
BP_CONFIG_DIR=/home/ubuntu/bp-bot/config
BP_SECRETS_DIR=/home/ubuntu/bp-bot/config/secrets
BP_LOG_DIR=/home/ubuntu/bp-bot/logs
BP_WORKTREE_ROOT=/tmp/bp-bot-worktrees

# Long-term post-migration layout.
BP_APP_REPO=/home/ubuntu/bp-bot/bp-assistant
BP_SKILLS_REPO=/home/ubuntu/bp-bot/bp-assistant-skills
BP_CODEX_CWD=/home/ubuntu/bp-bot
BP_PROMPTS_DIR=/home/ubuntu/bp-bot/.claude/cron-prompts

# Runtime-only local container maintenance.
BP_RUNTIME_CONTAINER=zulip-bot

# Non-secret config required by host cron jobs that DM Zulip summaries.
ZULIP_REALM=https://your-org.zulipchat.com

# Morning test override before the repo move:
# BP_APP_REPO=/srv/bot/app
# BP_SKILLS_REPO=/srv/bot/workspace
# BP_CODEX_CWD=/srv/bot
# BP_PROMPTS_DIR=/srv/bot/.claude/cron-prompts
# BP_SECRETS_DIR=/srv/bot/config/secrets
